// BachatKhata — Prisma schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DiscountType {
  PERCENTAGE
  FLAT
  CASHBACK
  FREEBIE
  OTHER
}

model Coupon {
  id              String       @id @default(uuid()) @db.Uuid
  brand           String?
  title           String
  category        String?
  discountType    DiscountType
  discountValue   Float?
  minimumSpend    Float?
  maximumDiscount Float?
  couponCode      String?
  expiryDate      DateTime?    @db.Timestamptz(3)
  source          String?
  rawText         String
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @db.Timestamptz(3)

  @@index([couponCode])
  @@index([expiryDate])
  @@map("coupons")
}
