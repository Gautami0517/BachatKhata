NODE_ENV=development
PORT=3000

# PostgreSQL connection string (pgvector-enabled database recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bachatkhata?schema=public

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=30000

# Swagger
SWAGGER_PATH=api/docs

# JWT — min 32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_ISSUER=cvault
# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:tiwarygautami835@gmail.com
