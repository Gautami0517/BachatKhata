NODE_ENV=development
PORT=3000

# PostgreSQL connection string (pgvector-enabled database recommended)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bachatkhata?schema=public"

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=30000

# Swagger
SWAGGER_PATH=api/docs
